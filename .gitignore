# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
out/
.next/
.turbo/

# TypeScript
*.tsbuildinfo

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.netlify
CREDENTIALS_BACKUP.env
CREDENTIALS_BACKUP_FILLED.env
CREDENTIALS_CONSOLIDATED_BACKUP.env
supabase.credentials.backup.txt
food-ordering-backend/render.env
food-ordering-backend/render.env.no-whatsapp

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# Testing
coverage/
*.lcov
.nyc_output/

# Package manager locks (keep package-lock.json for reproducible installs)
yarn.lock
pnpm-lock.yaml
bun.lockb

# Vite
*.local

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Deployment
.vercel/
.netlify/

# Supabase (local dev)
.supabase/

# Cloudinary / uploads (local temp)
uploads/
temp/

# Screenshots (may contain sensitive info)
screenshots/

# Misc
*.bak
*.tmp
*.temp
MASTER_DEVELOPER_GUIDE.md
PROPRIETAIRE-SECRET.md
