# =============================================================================
# Crêpe Time Tunisia — PRODUCTION Environment Variables (Frontend)
# =============================================================================
# For Netlify: set these in Site Settings > Environment Variables instead.
# These values are fallbacks baked into the Vite build.
# =============================================================================

# Backend API (Render)
VITE_API_BASE_URL=https://crepe-time-tunisia.onrender.com

# Restaurant ID — hardcode this to skip the API lookup on /menu (instant load).
