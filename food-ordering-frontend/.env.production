# Or: visit crepetime.tn/menu once, wait for redirect, copy the UUID from the URL.
VITE_RESTAURANT_ID=3188b88d-b11f-4265-8e35-6f1d49c2b1dc

# Supabase
VITE_SUPABASE_URL=https://kjhuwmbddxuyrtycdezr.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_-ujS-PZzk5K0fw39fqu9ng_1LXhYwUR

# App
VITE_APP_URL=https://crepetime.tn
VITE_APP_NAME=Crêpe Time Tunisia
