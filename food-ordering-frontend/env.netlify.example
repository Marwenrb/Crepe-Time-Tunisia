# =============================================================================
# Crêpe Time Tunisia — Variables Netlify (Frontend)
# =============================================================================
# 1. Copier ce fichier : cp env.netlify.example .env.netlify
# 2. Remplir les valeurs ci-dessous avec vos credentials
# 3. Netlify : Site settings > Environment variables > Import from .env
#    Ou ajouter manuellement chaque variable
# =============================================================================

# -----------------------------------------------------------------------------
# OBLIGATOIRE — Remplacer par vos vraies valeurs
# -----------------------------------------------------------------------------

# URL de votre API backend (Render, Railway, etc.)
VITE_API_BASE_URL=https://your-backend.onrender.com

# Supabase — Dashboard > Settings > API
# Project URL (même que SUPABASE_URL du backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
# Clé "anon public" (PAS la Service Role — Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------------------
# Optionnel
# -----------------------------------------------------------------------------
# VITE_APP_NAME=Crêpe Time Tunisia
# VITE_APP_URL=https://crepe-time.netlify.app
