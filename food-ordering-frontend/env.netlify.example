# =============================================================================
# Crepe Time Tunisia - Netlify frontend variables
# =============================================================================
# 1) Copy this file: cp env.netlify.example .env.netlify
# 2) Fill values below
# 3) Netlify > Site settings > Environment variables > Import from .env
# =============================================================================

# Required
VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_APP_URL=https://crepetime.netlify.app

# Optional
# VITE_APP_NAME=Crepe Time Tunisia
